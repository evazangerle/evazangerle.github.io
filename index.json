[{"authors":["admin"],"categories":null,"content":"Eva is a postdoctoral researcher at the Department of Computer Science at the University of Innsbruck, Austria. Her primary scientific interests focus on (context-aware) recommender systems and user modeling aspects of music information retrieval tasks. She earned her Ph.D. from the University of Innsbruck in the field of recommender systems for collaborative social media platforms. During her postdoc, she did short-term research stays at Ritsumeikan University in Kyoto, Japan (funded by a Postdoctoral Fellowship for Overseas Researchers from the Japan Society for the Promotion of Science), Freie Universität Berlin, Germany (funded by the Global Faculty Program of Freie Universität) and Johannes-Kepler-Universität Linz, Austria.\nEva is also co-author of a book on MySQL (currently in it\u0026rsquo;s 3rd edition). For more information on the book, visit Rheinwerk Verlag (the publisher) or the book\u0026rsquo;s website .\n","date":-62135596800,"expirydate":-62135596800,"kind":"taxonomy","lang":"en","lastmod":1581432981,"objectID":"2525497d367e79493fd32b198b28f040","permalink":"https://evazangerle.at/authors/admin/","publishdate":"0001-01-01T00:00:00Z","relpermalink":"/authors/admin/","section":"authors","summary":"Eva is a postdoctoral researcher at the Department of Computer Science at the University of Innsbruck, Austria. Her primary scientific interests focus on (context-aware) recommender systems and user modeling aspects of music information retrieval tasks. She earned her Ph.D. from the University of Innsbruck in the field of recommender systems for collaborative social media platforms. During her postdoc, she did short-term research stays at Ritsumeikan University in Kyoto, Japan (funded by a Postdoctoral Fellowship for Overseas Researchers from the Japan Society for the Promotion of Science), Freie Universität Berlin, Germany (funded by the Global Faculty Program of Freie Universität) and Johannes-Kepler-Universität Linz, Austria.","tags":null,"title":"Dr. Eva Zangerle","type":"authors"},{"authors":["Janek Bevendorff","Bilal Ghanem","Anastasia Giachanou","Mike Kestemont","Enrique Manjavacas","Martin Potthast","Francisco Rangel","Paolo Rosso","Günther Specht","Efstathios Stamatatos","Benno Stein","Matti Wiegmann","Eva Zangerle"],"categories":null,"content":"","date":1577836800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1586872242,"objectID":"2d480a3b8522fb929dd008c07eaed655","permalink":"https://evazangerle.at/publication/ecir-20-pan/","publishdate":"2020-04-14T13:47:12.081308Z","relpermalink":"/publication/ecir-20-pan/","section":"publication","summary":"The paper gives a brief overview of the four shared tasks that are to be organized at the PAN 2020 lab on digital text forensics and stylometry, hosted at CLEF conference. The tasks include author profiling, celebrity profiling, cross-domain author verification, and style change detection, seeking to advance the state of the art and to evaluate it on new benchmark datasets.","tags":null,"title":"Shared Tasks on Authorship Analysis at PAN 2020","type":"publication"},{"authors":["Eva Zangerle","Martin Pichl","Markus Schedl"],"categories":null,"content":"","date":1577836800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1584027053,"objectID":"4d16dae00f627324c55ec2ffd11d1c23","permalink":"https://evazangerle.at/publication/tismir-20/","publishdate":"2020-03-12T15:02:28.184942Z","relpermalink":"/publication/tismir-20/","section":"publication","summary":"","tags":null,"title":"User Models for Culture-Aware Music Recommendation: Fusing Acoustic and Cultural Cues","type":"publication"},{"authors":["Hsiao-Tzu Hung","Yu-Hua Chen","Maximilian Mayerl","Michael Vötter","Eva Zangerle","Yi-Hsuan Yang"],"categories":null,"content":"","date":1575158400,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"0e5e8bfa28e494f62e3b205cc97c1b97","permalink":"https://evazangerle.a