rle.at/publication/hiebelidentifikation/","publishdate":"2020-01-14T06:41:35.246801Z","relpermalink":"/publication/hiebelidentifikation/","section":"publication","summary":"","tags":null,"title":"Zur Identifikation und Verortung von Bergnamen in alpiner Literatur","type":"publication"},{"authors":["Asir Saeed","Suzana Ilic","Eva Zangerle"],"categories":null,"content":"","date":1546300800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"5c260f15b8885f0e7b8ab154c8793a38","permalink":"https://evazangerle.at/publication/neurips-creativity-19/","publishdate":"2020-01-14T06:41:35.238214Z","relpermalink":"/publication/neurips-creativity-19/","section":"publication","summary":"","tags":null,"title":"Creative GANs for generating poems, lyrics, and metaphors","type":"publication"},{"authors":["Asmita Poddar","Eva Zangerle","Yi-Hsuan Yang"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1581261668,"objectID":"72d468fe0fc10210ec0095bcbaa81d5e","permalink":"https://evazangerle.at/publication/smc-2018/","publishdate":"2020-01-14T06:41:35.250186Z","relpermalink":"/publication/smc-2018/","section":"publication","summary":"","tags":null,"title":"#nowplaying-RS: A New Benchmark Dataset for Building Context-Aware Music Recommender Systems ","type":"publication"},{"authors":["Eva Zangerle","Michael Tschuggnall","Stefan Wurzinger","Günther Specht"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1581261668,"objectID":"6e8e9620881820b46000a1e2c06ece10","permalink":"https://evazangerle.at/publication/ecir-2018/","publishdate":"2020-01-14T06:41:35.252729Z","relpermalink":"/publication/ecir-2018/","section":"publication","summary":"In recent years, approaches in music information retrieval have been based on multimodal analyses of music incorporating audio as well as lyrics features. Because most of those approaches are lacking reusable, high-quality datasets, in this work we propose ALF-200k, a publicly available, novel dataset including 176 audio and lyrics features of more than 200,000 tracks and their attribution to more than 11,000 user-created playlists. While the dataset is of general purpose and thus, may be used in experiments for diverse music information retrieval problems, we present a first multimodal study on playlist features and particularly analyze, which type of features are shared within specific playlists and thus, characterize it. We show that while acoustic features act as the major glue between tracks contained in a playlists, also lyrics features are a powerful means to attribute tracks to playlists.","tags":null,"title":"ALF-200k: Towards Extensive Multimodal Analyses of Music Tracks and Playlists","type":"publication"},{"authors":["Martin Pichl","Bernward Pichl","Eva Zangerle"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"773f5f0b1e815009eabcc12fad3ee06b","permalink":"https://evazangerle.at/publication/dblp-confsigir-pichl-pz-18/","publishdate":"2020-01-14T06:41:35.248666Z","relpermalink":"/publication/dblp-confsigir-pichl-pz-18/","section":"publication","summary":"","tags":null,"title":"Carl: Sports Award Recommender","type":"publication"},{"authors":["Eva Zangerle","Martin Pichl"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"3fc861d0f9b69c12417668d69135381d","permalink":"https://evazangerle.at/publication/zangerle-ismir-18/","publishdate":"2020-01-14T06:41:35.24728Z","relpermalink":"/publication/zangerle-ismir-18/","section":"publication","summary":"","tags":null,"title":"Content-based User Models: Modeling the Many Faces of Musical Preference","type":"publication"},{"authors":["Eva Zangerle","Martin Pichl","Markus Schedl"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"2e7f82453918432118f771c3fce3f69c","permalink":"https://evazangerle.at/publication/zangerle-umap-2018/","publishdate":"2020-01-14T06:41:35.24916Z","relpermalink":"/publication/zangerle-umap-2018/","section":"publication","summary":"","tags":null,"title":"Culture-Aware Music Recommendation","type":"publication"},{"authors":["Christian Esswein","Markus Schedl","Eva Zangerle"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"a02f854dbf19b5507b3d35059f34c848","permalink":"https://evazangerle.at/publication/milc-2018/","publishdate":"2020-01-14T06:41:35.252221Z","relpermalink":"/publication/milc-2018/","section":"publication","summary":"","tags":null,"title":"geMsearch: Personalized Explorative Music Search","type":"publication"},{"authors":["Robert Binna","Eva Zangerle","Martin Pichl","Günther Specht","Viktor Leis"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"8979bc37f92d3c7fb545ae979232b2da","permalink":"https://evazangerle.at/publication/binna-sigmod-18/","publishdate":"2020-01-14T06:41:35.250672Z","relpermalink":"/publication/binna-sigmod-18/","section":"publication","summary":"","tags":null,"title":"HOT: A Height Optimized Trie Index for Main-Memory Database Systems","type":"publication"},{"authors":["Martin Pichl","Eva Zangerle"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"98841a8a99c4f29651afd60c5136f377","permalink":"https://evazangerle.at/publication/zangerle-cbmi-18/","publishdate":"2020-01-14T06:41:35.248163Z","relpermalink":"/publication/zangerle-cbmi-18/","section":"publication","summary":"In recent years, music aficionados have increasingly been consuming music via public music streaming platforms. Due to the size of the collections provided, music recommender systems have become a vital component as these aim to provide recommendations that match the user's current context as, throughout the day, users listen to music in numerous different contexts and situations. In this paper, we propose a multi-context-aware track recommender system that jointly exploits information about the current situation and musical preferences of users. To jointly model users by their situational and musical preferences, we cluster users based on their situational features and similarly, cluster music tracks based on their content features. Our experiments show that by relying on Factorization Machines for the computation of recommendations, the proposed approach allows to successfully leverage interaction effects between listening histories, situational and track content information, substantially outperforming a set of baseline recommenders.","tags":null,"title":"Latent Feature Combination for Multi-Context Music Recommendation","type":"publication"},{"authors":["Bettina Larl","Eva Zangerle"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"7b12830568c46a97569e0d6867eb8ef5","permalink":"https://evazangerle.at/publication/zangerle-cmc-18/","publishdate":"2020-01-14T06:41:35.247728Z","relpermalink":"/publication/zangerle-cmc-18/","section":"publication","summary":"","tags":null,"title":"Leiwand Oida: Geolocating Regional Linguistic Variation of German on Twitter","type":"publication"},{"authors":["Eva Zangerle","Chih-Ming Chen","Ming-Feng Tsai","Yi-Hsuan Yang"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"15d9d56e01aeb8b0b160ae777e76e2da","permalink":"https://evazangerle.at/publication/taffc-18/","publishdate":"2020-01-14T06:41:35.251194Z","relpermalink":"/publication/taffc-18/","section":"publication","summary":"","tags":null,"title":"Leveraging Affective Hashtags for Ranking Music Recommendations","type":"publication"},{"authors":["Eva Zangerle","Claudia Müller-Birn"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"1f19f9739de875e2119068dfaf55e3ec","permalink":"https://evazangerle.at/publication/wikiworkshop-18/","publishdate":"2020-01-14T06:41:35.25171Z","relpermalink":"/publication/wikiworkshop-18/","section":"publication","summary":"","tags":null,"title":"Recommendation-Assisted Data Curation for Wikidata","type":"publication"},{"authors":["Ilknur Celik","Ilaria Torre","Frosina Koceva","Christine Bauer","Eva Zangerle","Bart Knijnenburg"],"categories":null,"content":"","date":1514764800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"59fb53007bc74e97c700bfad1c603c51","permalink":"https://evazangerle.at/publication/iuadaptme-umap-2018/","publishdate":"2020-01-14T06:41:35.249672Z","relpermalink":"/publication/iuadaptme-umap-2018/","section":"publication","summary":"","tags":null,"title":"UMAP 2018 Intelligent User-Adapted Interfaces: Design and Multi-Modal Evaluation (IUadaptMe) Workshop Chairs' Welcome and Organization","type":"publication"},{"authors":["Benjamin Murauer","Eva Zangerle","Günther Specht"],"categories":null,"content":"","date":1483228800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"5e8795778a619dbdeb1507aeb9b66f2b","permalink":"https://evazangerle.at/publication/hicss-17/","publishdate":"2020-01-14T06:41:35.25879Z","relpermalink":"/publication/hicss-17/","section":"publication","summary":"Social media has become an important part of the lives of their hundreds of millions of users. Hackers make use of the large target audience by sending malicious content, often by hijacking existing accounts. This phenomenon has caused widespread research on how to detect hacked accounts, where different approaches exist. This work sets out to analyze the possibilities of including the reactions of hacked Twitter accounts’ peers into a detection system. Based on a dataset of six million tweets crawled from Twitter over the course of two years, we select a subset of tweets in which users react to alleged hacks of other accounts. We then gather and analyze the responses to those messages to reconstruct the conversations made. A quantitative analysis of these conversations shows that 30% of the users that are allegedly being hacked reply to the accusations, suggesting that these users acknowledge that their account was hacked.","tags":null,"title":"A Peer-Based Approach on Analyzing Hacked Twitter Accounts","type":"publication"},{"authors":["Eva Zangerle","Michael Tschuggnall","Günther Specht"],"categories":null,"content":"","date":1483228800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1578984237,"objectID":"6d92213046cbcdd5ad4f97fc5dee20c9","permalink":"https://evazangerle.at/publication/coherent-17/","publishdate":"2020-01-14T06:41:35.254908Z","relpermalink":"/publication/coherent-17/","section":"publication","summary":"","tags":null,"title":"Analyzing Coherent Characteristics in Music Playlists","type":"publication"},{"authors":["Gerald Hiebel","Gerhard Rampl","Claudia Posch","Elisabeth Gruber","Eva Zangerle"],"categories":null,"content":"","date":1483228800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1586077534,"objectID":"847af6a90ec37f7198a564b7dfafc74d","permalink":"https://evazangerle.at/publication/namenstagung-17/","publishdate":"2020-01-14T06:41:35.256615Z","relpermalink":"/publication/namenstagung-17/","section":"publication","summary":"","tags":null,"title":"Bergnamen – Bergwelten. Toponymie im (Kon-)Text","type":"publication"},{"authors":["Gerald Hiebel","Claudia Posch","Gerhard Rampl","Eva Zangerle"],"categories":null,"content":"","date":1483228800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1586077534,"objectID":"bf0997e7944027776265d56fc